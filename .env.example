# Backend — auth
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=true

# Backend — limites médias (en octets)
MAX_IMAGE_SIZE_BYTES=15728640
MAX_VIDEO_SIZE_BYTES=52428800

# Backend — notifications push (générer avec: pnpm --filter @familyspeak/backend generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ton-email@example.com

# Caddy — nom de domaine et DuckDNS
DOMAIN=tonsousdomaine.duckdns.org
DUCKDNS_API_TOKEN=
