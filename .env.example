# Backend — auth
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=true

# Backend — limites médias (en octets)
MAX_IMAGE_SIZE_BYTES=15728640
MAX_VIDEO_SIZE_BYTES=52428800

# Backend — notifications push (générer avec: pnpm --filter @familyspeak/backend generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ton-email@example.com

# Caddy — nom de domaine et DuckDNS
DOMAIN=tonsousdomaine.duckdns.org
DUCKDNS_API_TOKEN=

# Caddy — domaine secondaire www.baschet.fr (certificat via défi DNS-01 chez OVH)
# ovh-eu pour un compte OVH Europe. Générer les clés API sur https://api.ovh.com/createToken
# (droits : GET/POST/PUT/DELETE sur /domain/zone/baschet.fr/*).
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=
OVH_APPLICATION_SECRET=
OVH_CONSUMER_KEY=

# Backend — auto-réponse Hermes agent à la place de visperine (conversations 1:1 uniquement)
# Nécessite `hermes gateway` lancé sur la machine hôte (API_SERVER_ENABLED=true côté Hermes).
# Sur Docker Desktop (Windows/Mac), host.docker.internal résout vers l'hôte même si Hermes
# écoute sur 127.0.0.1 ; sur Linux natif il faudrait `extra_hosts: host.docker.internal:host-gateway`
# dans docker-compose.yml, ou faire écouter Hermes sur l'IP du réseau docker.
HERMES_ENABLED=false
HERMES_API_URL=http://host.docker.internal:8642
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
HERMES_BOT_USERNAME=visperine
# Nombre de messages précédents envoyés à chaque appel (fenêtre glissante, borne les tokens)
HERMES_HISTORY_LIMIT=30
# Nombre de messages sortis de la fenêtre à accumuler avant de les compacter en un résumé
HERMES_COMPACT_BATCH_SIZE=20
# Nombre de nouveaux messages d'un utilisateur avant de rafraîchir son profil IA (visible dans l'appli)
HERMES_PROFILE_UPDATE_BATCH_SIZE=10

# Backend — espace de jeu voxel partagé (accessible via le bouton 🧱 depuis la liste des discussions)
GAME_ENABLED=false
