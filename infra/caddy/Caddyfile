{$DOMAIN} {
    tls {
        dns duckdns {$DUCKDNS_API_TOKEN}
    }

    handle /api/* {
        reverse_proxy backend:3000
    }

    handle /ws {
        reverse_proxy backend:3000
    }

    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }

    encode gzip
}
